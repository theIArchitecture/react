{
  "discovery-root": ".",
  "bundled-defaults-path": "~/.iarch",
  "version": "1.0",
  "default-layer": "Base",
  "governance": {
    "embedding-model": "nomic-embed-text",
    "ollama-host": "http://localhost:11434",
    "embedding-max-types": 600,
    "embedding-batch-delay-ms": 50,
    "dbscan-epsilon": 0.30,
    "dbscan-min-pts": 3,
    "analysis-seed": 42,
    "min-cluster-purity": 0.6,
    "duplicate-threshold": 0.95
  },
  "layer-hierarchy": {
    "Base": { "inherits-from": [] },
    "Shared": { "inherits-from": ["Base"] },
    "DevTools": { "inherits-from": ["Base", "Shared"] },
    "Internal": { "inherits-from": ["Base", "Shared"] },
    "Bindings": { "inherits-from": ["Base", "Shared", "Internal"] },
    "Reconciler": { "inherits-from": ["Base", "Shared", "Internal"] },
    "PublicAPI": { "inherits-from": ["Base", "Shared", "Internal", "Reconciler", "Bindings", "DevTools"] }
  },
  "engine-config": {
    "parallel-threads": 9,
    "max-file-size-bytes": 500000,
    "files-per-batch": 50,
    "progressive-output-threshold": 200,
    "cache-root-path": "D:/cache/react",
    "ignore-patterns": [
      "node_modules",
      "bin", "build", "dist", "out", "artifacts",
      ".git", ".iarch", ".modulus", ".claude",
      "__tests__", "__mocks__",
      "test-fixtures", "fixtures",
      "scripts", "tools",
      "vendor", "third_party", "third-party",
      "__pycache__", ".pytest_cache",
      "!packages",
      "coverage", ".nyc_output", "flow-typed",
      "*.test.ts", "*.spec.ts", "*.test.js", "*.spec.js",
      "*.test.tsx", "*.spec.tsx",
      "*.min.js", "*.bundle.js"
    ]
  }
}
