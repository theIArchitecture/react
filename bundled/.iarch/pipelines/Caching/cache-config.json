{
  "name": "cache-config",
  "description": "Config-only include: shared cache type, value-type, and cache-name settings for all governance and dashboard caches. Zero processors — include via @Caching/cache-config in any pipeline that reads or writes these caches. Parent pipeline config always wins on conflicts.",
