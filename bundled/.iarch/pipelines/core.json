{
  "name": "@core",
  "description": "Universal pipeline foundation. Always include first. No exceptions. Initializes IArch context and declares all cache type metadata for the engine. Adding a new cache? Register it here.",
  "processors": ["iarch-init"],
  "config": {
    "cache.dependency-graph.cache-type": "file",
    "cache.dependency-graph.value-type": "IArchitecture.Core.Models.DependencyGraph, IArchitecture.Core",
    "cache.dependency-graph-stats.cache-type": "hybrid",
    "cache.dependency-graph-stats.value-type": "IArchitecture.Core.Models.CachedGraphStats, IArchitecture.Core",
    "cache.violation-index.cache-type": "hybrid",
    "cache.violation-index.value-type": "IArchitecture.Core.Models.ViolationIndex, IArchitecture.Core",
    "cache.anomaly-clusters.cache-type": "raw",
    "cache.anomaly-clusters.value-type": "System.Collections.Generic.List`1[[IArchitecture.GovernanceIntelligence.Models.AnomalyCluster, IArchitecture.GovernanceIntelligence]]",
    "cache.ca-pipeline-template.cache-type": "raw",
    "cache.ca-pipeline-template.cache-name": "pipeline-remediation-template.json",
    "cache.cochange-matrix.cache-type": "file",
    "cache.cochange-matrix.value-type": "IArchitecture.Core.Models.CoChangeMatrix, IArchitecture.Core",
    "cache.source-metadata.cache-type": "raw",
    "cache.source-metadata.value-type": "IArchitecture.Shared.Models.DashboardData, IArchitecture.Shared",
    "cache.governance-ledger.cache-type": "raw",
    "cache.governance-ledger.value-type": "System.Collections.Generic.List`1[[IArchitecture.GovernanceIntelligence.Models.GovernanceLedgerEntry, IArchitecture.GovernanceIntelligence]]",
    "cache.entropy-history.cache-type": "raw",
    "cache.entropy-history.value-type": "System.Collections.Generic.List`1[[IArchitecture.GovernanceIntelligence.Models.EntropyHistoryEntry, IArchitecture.GovernanceIntelligence]]",
    "cache.governance-stats.cache-type": "raw",
    "cache.governance-stats.value-type": "IArchitecture.GovernanceIntelligence.Models.GovernanceCycleStats, IArchitecture.GovernanceIntelligence",
    "cache.pr-scan-history.cache-type": "raw",
    "cache.pr-scan-history.value-type": "System.Collections.Generic.List`1[[IArchitecture.Shared.Models.PrScanEntry, IArchitecture.Shared]]",
    "cache.pr-scan-history.cache-name": "pr-scan-history",
    "cache.pipeline-run-history.cache-type": "raw",
    "cache.pipeline-run-history.value-type": "System.Collections.Generic.List`1[[IArchitecture.Shared.Models.PipelineRunEntry, IArchitecture.Shared]]",
    "cache.pipeline-run-history.cache-name": "pipeline-run-history",
    "cache.pipeline-run-history-html.cache-type": "raw",
    "cache.pipeline-run-history-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.pipeline-run-history-html.cache-name": "pipeline-run-history.html",
    "cache.dashboard-html.cache-type": "raw",
    "cache.dashboard-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.dashboard-html.cache-name": "dashboard.html",
    "cache.dashboard-json.cache-type": "raw",
    "cache.dashboard-json.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.dashboard-json.cache-name": "dashboard.json",
    "cache.governance-html.cache-type": "raw",
    "cache.governance-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.governance-html.cache-name": "governance.html",
    "cache.governance-efficacy-html.cache-type": "raw",
    "cache.governance-efficacy-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.governance-efficacy-html.cache-name": "governance-efficacy.html",
    "cache.governance-voting-html.cache-type": "raw",
    "cache.governance-voting-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.governance-voting-html.cache-name": "governance-voting.html",
    "cache.governance-ledger-html.cache-type": "raw",
    "cache.governance-ledger-html.value-type": "System.Byte[], System.Private.CoreLib",
    "cache.governance-ledger-html.cache-name": "governance-ledger.html"
  }
}
