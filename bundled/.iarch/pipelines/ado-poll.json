{
  "name": "ADO CA* Status Poll",
  "description": "Hourly poll: detect Approved/Rejected/Promoted CA* proposals in ADO Work Items, write state transitions to ledger, trigger cluster-remediation and governance-promote ADO pipelines, refresh dashboard.",
  "processors": [
    "@Caching/cache-config",
    "source-metadata-cache-loader",
    "entropy-history-cache-loader",
    "governance-stats-cache-loader",
    "ado-environment-provider",
    "governance-ledger-reader",
    "ado-status-poller",
    "governance-ledger-state-transition",
    "ado-bot-commit",
    "ado-workflow-dispatcher",
    "@DashboardRefresh/dashboard-refresh"
  ],
  "config": {
    "bot-commit-message": "IArchitecture: governance ledger state transitions (ado-poll)",
    "bot-files": ".iarch/governance-ledger.jsonl"
  }
}
