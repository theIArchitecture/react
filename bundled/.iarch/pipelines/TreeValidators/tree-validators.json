    "cross-boundary-type-validator",
    "shared-kernel-validator",
    "test-structure-validator",
    "dependency-stability-validator",
    "directory-depth-limits-validator",
    "file-count-limits-validator",
    "test-directory-colocation-validator",
    "abstract-metrics-validator"
