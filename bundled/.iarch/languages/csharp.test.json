{
  "$schema": "../schemas/language-definition.schema.json",
  "language": "csharp",
  "display_name": "C#",
  "file_extensions": [ ".cs", ".csx" ],

  "layer_detection": {
    "layers": {
      "Repository": {
        "path_patterns": [ "repository", "data", "persistence", "dao" ],
        "base_class_patterns": [ "RepositoryArchitecture", "IRepositoryArchitecture", "RepositoryBase", "BaseRepository" ],
        "interface_patterns": [ "IRepository", "IRepositoryArchitecture" ],
        "naming_patterns": [ "Repository$", "Repo$", ".*Repository.*" ],
        "import_patterns": [ "using.*\\.Repository", "using.*\\.Data", "using.*\\.Persistence" ]
      },

      "Domain": {
        "path_patterns": [ "domain", "business", "core", "model" ],
        "base_class_patterns": [ "DomainArchitecture", "IDomainArchitecture", "DomainEntity", "Entity" ],
        "interface_patterns": [ "IDomain", "IDomainArchitecture", "IEntity" ],
        "naming_patterns": [ "Entity$", "Model$", ".*Domain.*" ],
        "import_patterns": [ "using.*\\.Domain", "using.*\\.Business", "using.*\\.Core" ]
      },

      "Service": {
        "path_patterns": [ "service", "application", "usecase", "business" ],
        "base_class_patterns": [ "ServiceArchitecture", "IServiceArchitecture", "ServiceBase", "BaseService" ],
        "interface_patterns": [ "IService", "IServiceArchitecture", "IApplicationService" ],
        "naming_patterns": [ "Service$", "Manager$", "Handler$", ".*Service.*" ],
        "import_patterns": [ "using.*\\.Services", "using.*\\.Application", "using.*\\.UseCases" ]
      },

      "API": {
        "path_patterns": [ "controller", "api", "endpoint", "web", "presentation" ],
        "base_class_patterns": [ "ControllerArchitecture", "IControllerArchitecture", "ControllerBase", "Controller" ],
        "interface_patterns": [ "IController", "IControllerArchitecture", "IEndpoint" ],
        "naming_patterns": [ "Controller$", "Endpoint$", "Api$", ".*Controller.*" ],
        "import_patterns": [ "using.*\\.Controllers", "using.*\\.Api", "using.*\\.Web" ]
      },

      "Infrastructure": {
        "path_patterns": [ "infrastructure", "common", "shared", "utility" ],
        "base_class_patterns": [ "InfrastructureArchitecture" ],
        "interface_patterns": [ "IInfrastructure" ],
        "naming_patterns": [],
        "import_patterns": [ "using.*\\.Infrastructure", "using.*\\.Common", "using.*\\.Shared" ]
      },

      "Configuration": {
        "path_patterns": [ "config", "configuration", "settings" ],
        "base_class_patterns": [ "ConfigurationArchitecture" ],
        "interface_patterns": [ "IConfiguration" ],
        "naming_patterns": [ "Config$", "Settings$", "Options$" ],
        "import_patterns": [ "using.*\\.Configuration", "using.*\\.Config" ]
      }
    }
  },

  "syntax_patterns": {
    "class_declaration": "class\\s+(\\w+)\\s*(?::\\s*([^{,\\r\\n]+))?",
    "import_statement": "using\\s+(?:static\\s+)?([^;\\s]+);",
    "interface_implementation": ":\\s*[^{]*\\b(I\\w+Architecture|I\\w+)\\b",
    "method_declaration": "(public|private|protected|internal|static)\\s+(?:async\\s+)?(?:Task<[^>]+>|Task|\\w+)\\s+(\\w+)\\s*\\("
  },

  "field_extraction_patterns": [
    {
      "name": "field_declaration",
      "description": "Matches field declarations like: private Type _field;",
      "pattern": "(?:public\\s+|private\\s+|protected\\s+|internal\\s+)?(?:static\\s+)?(?:readonly\\s+)?(?:const\\s+)?(\\w+(?:<[\\w\\s,<>]+>)?)\\s+(_?\\w+)\\s*(?:;|=|{)",
      "type_group": 1,
      "name_group": 2,
      "is_property": false
    },
    {
      "name": "property_declaration",
      "description": "Matches property declarations like: public Type Property { get; set; }",
      "pattern": "(?:public\\s+|private\\s+|protected\\s+|internal\\s+)?(?:static\\s+)?(?:readonly\\s+)?(\\w+(?:<[\\w\\s,<>]+>)?)\\s+(\\w+)\\s*\\{",
      "type_group": 1,
      "name_group": 2,
      "is_property": true
    }
  ],

  "parsing_patterns": {
    "namespace": "^\\s*namespace\\s+([\\w\\.]+)",
    "import": "^\\s*using\\s+(?<modifier>static\\s+)?(?<module>[\\w\\.]+)\\s*;",
    "type_declaration": "(?:public\\s+|private\\s+|protected\\s+|internal\\s+)?(?:static\\s+)?(?:sealed\\s+)?(?:abstract\\s+)?(class|interface|enum|struct|record)\\s+(\\w+)(?:\\s*<[^>]+>)?(?:\\s*:\\s*([^{]+))?",
    "type_keywords": [ "class", "interface", "enum", "struct", "record" ],
    "method_declaration": "(?:public\\s+|private\\s+|protected\\s+|internal\\s+)?(?:static\\s+)?(?:virtual\\s+)?(?:override\\s+)?(?:async\\s+)?(\\w+(?:<[\\w\\s,<>]+>)?)\\s+(\\w+)\\s*\\(([^)]*)\\)",
    "instantiation": "new\\s+([\\w\\.]+)(?:<[^>]+>)?\\s*\\(",
    "comment_single_line": "//(.*)$",
    "comment_multi_line": "/\\*(.*?)\\*/",
    "comment_documentation": "///(.*)$"
  },

  "plain_import_behavior": "skip",

  "transformation_rules": {
    "import_template": "using {namespace};",
    "import_insert_location": "after_last_import",
    "import_removal_pattern": "^\\s*using\\s+{namespace}\\s*;\\s*$"
  },

  "formatting_rules": {
    "indent_size": 4,
    "increase_indent_triggers": [ "{" ],
    "decrease_indent_triggers": [ "}" ],
    "decrease_before_line": true
  },

  "syntax_validation": {
    "balanced_pairs": [
      { "open": "{", "close": "}" },
      { "open": "(", "close": ")" },
      { "open": "[", "close": "]" }
    ],
    "invalid_patterns": [ ";;", "using\\s+[^;]*$" ]
  },

  "comment_styles": [ "//", "/*", "*/", "///", "/**" ]
}
