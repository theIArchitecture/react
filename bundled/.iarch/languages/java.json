{
  "language": "java",
  "display_name": "Java",
  "file_extensions": [".java"],

  "layer_detection": {
    "layers": {
      "API": {
        "path_patterns": ["controller", "web", "rest", "endpoint"],
        "base_class_patterns": ["ControllerArchitecture", "IControllerArchitecture"],
        "interface_patterns": ["IControllerArchitecture"],
        "naming_patterns": ["Controller$", "Resource$", "Endpoint$"],
        "import_patterns": ["controller", "rest", "web"]
      },

      "Service": {
        "path_patterns": ["service", "business"],
        "base_class_patterns": ["ServiceArchitecture", "IServiceArchitecture"],
        "interface_patterns": ["IServiceArchitecture"],
        "naming_patterns": ["Service$", "ServiceImpl$"],
        "import_patterns": ["service", "business"]
      },

      "Repository": {
        "path_patterns": ["repository", "dao", "persistence"],
        "base_class_patterns": ["RepositoryArchitecture", "IRepositoryArchitecture"],
        "interface_patterns": ["IRepositoryArchitecture"],
        "naming_patterns": ["Repository$", "RepositoryImpl$", "DAO$"],
        "import_patterns": ["repository", "dao", "persistence"]
      },

      "Domain": {
        "path_patterns": ["model", "domain", "entity"],
        "base_class_patterns": ["DomainArchitecture", "IDomainArchitecture"],
        "interface_patterns": ["IDomainArchitecture"],
        "naming_patterns": ["Domain$", "Model$", "Entity$"],
        "import_patterns": ["domain", "entity", "model"]
      },

      "DTO": {
        "path_patterns": ["dto", "request", "response"],
        "base_class_patterns": [],
        "interface_patterns": [],
        "naming_patterns": ["DTO$", "Request$", "Response$"],
        "import_patterns": ["dto", "request", "response"]
      },

      "Configuration": {
        "path_patterns": ["config", "configuration"],
        "base_class_patterns": [],
        "interface_patterns": [],
        "naming_patterns": [],
        "import_patterns": []
      },

      "Utility": {
        "path_patterns": ["util", "helper", "common"],
        "base_class_patterns": [],
        "interface_patterns": [],
        "naming_patterns": [],
        "import_patterns": []
      },

      "Lambda": {
        "path_patterns": ["lambda", "handler"],
        "base_class_patterns": [],
        "interface_patterns": [],
        "naming_patterns": [],
        "import_patterns": []
      },

      "Integration": {
        "path_patterns": ["client", "adapter"],
        "base_class_patterns": [],
        "interface_patterns": [],
        "naming_patterns": [],
        "import_patterns": []
      }
    }
  },

  "parsing_patterns": {
    "namespace": "^\\s*package\\s+([\\w\\.]+)\\s*;",
    "import": "^\\s*import\\s+(?<modifier>static\\s+)?(?<module>[\\w\\.\\*]+)\\s*;",
    "type_declaration": "(?:public\\s+|private\\s+|protected\\s+)?(?:static\\s+)?(?:final\\s+)?(class|interface|enum)\\s+(\\w+)(?:\\s+extends\\s+(\\w+))?(?:\\s+implements\\s+([\\w\\s,]+))?",
    "type_keywords": ["class", "interface", "enum"],
    "method_declaration": "(?:public\\s+|private\\s+|protected\\s+)?(?:static\\s+)?(?:final\\s+)?(?:synchronized\\s+)?(\\w+|\\w+<[\\w\\s,<>]+>)\\s+(\\w+)\\s*\\(([^)]*)\\)(?:\\s+throws\\s+[\\w\\s,]+)?",
    "comment_single_line": "//(.*)$",
    "comment_multi_line": "/\\*(.*?)\\*/",
    "comment_documentation": "/\\*\\*(.*?)\\*/"
  },

  "plain_import_behavior": "skip",

  "transformation_rules": {
    "import_template": "import {namespace};",
    "import_insert_location": "after_last_import",
    "import_removal_pattern": "^\\s*import\\s+{namespace}\\s*;\\s*$"
  },

  "formatting_rules": {
    "indent_size": 4,
    "increase_indent_triggers": ["{"],
    "decrease_indent_triggers": ["}"],
    "decrease_before_line": true
  },

  "syntax_validation": {
    "balanced_pairs": [
      { "open": "{", "close": "}" },
      { "open": "(", "close": ")" },
      { "open": "[", "close": "]" }
    ],
    "invalid_patterns": [";;", "import\\s+[^;]*$"]
  },

  "comment_styles": ["//", "/*", "*/", "/**"]
}
