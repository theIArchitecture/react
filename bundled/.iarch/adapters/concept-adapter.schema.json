{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IArchitecture Concept Adapter Schema",
  "description": "Defines cross-language concept mappings for polyglot rule expansion",
  "type": "object",
  "required": ["name", "version", "domain", "concepts"],
  
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of this adapter"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this adapter"
    },
    "domain": {
      "type": "string",
      "enum": ["security", "reliability", "performance", "maintainability", "architecture"],
      "description": "Primary domain this adapter covers"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what this adapter covers"
    },
    
    "concepts": {
      "type": "object",
      "description": "Map of concept identifiers to their cross-language definitions",
      "additionalProperties": {
        "$ref": "#/definitions/concept"
      }
    }
  },
  
  "definitions": {
    "concept": {
      "type": "object",
      "required": ["description", "languageMappings"],
      "properties": {
        "description": {
          "type": "string",
          "description": "What this concept represents"
        },
        "risk": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"],
          "description": "Risk level associated with this concept"
        },
        "cwe": {
          "type": "string",
          "pattern": "^CWE-\\d+$",
          "description": "Associated CWE identifier if applicable"
        },
        "languageMappings": {
          "type": "object",
          "description": "Language-specific patterns for this concept",
          "additionalProperties": {
            "$ref": "#/definitions/languageMapping"
          }
        },
        "recommendedConcept": {
          "type": "string",
          "description": "Concept to recommend as a replacement (for risky concepts)"
        }
      }
    },
    
    "languageMapping": {
      "type": "object",
      "required": ["patterns"],
      "properties": {
        "patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Regex patterns that match this concept in this language"
        },
        "imports": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Common imports/packages associated with this pattern"
        },
        "replacement": {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string",
              "description": "Replacement code pattern"
            },
            "imports": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Imports required for the replacement"
            }
          }
        }
      }
    }
  }
}
