      "provides": [ "dependency-graph-stats", "dependency-graph-stats.transformed", "graph-fan-in-by-type", "graph-fan-out-by-type", "graph-fan-in-by-file", "graph-fan-out-by-file", "graph-stability-by-file" ],
	  "ide-hidden": true,
      "ide-required": true
    },
    {
      "id": "circular-dependency-validator",
      "name": "Circular Dependency Detector",
      "entry-point": "IArchitecture.ArchitectureRules.CircularDependencyDetector",
