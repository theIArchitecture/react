{
  "version": "1.0.0",
  "processor-path": "./IArchitecture.AnnotationFlush.dll",
  "processors": [
    {
      "id": "annotation-flush-partial",
      "name": "Annotation Flush - Partial",
      "entry-point": "IArchitecture.AnnotationFlush.AnnotationFlushProcessor",
      "requires": [ "annotations.partially-marked" ],
      "provides": [ "annotations.partially-written" ],
      "ide-hidden": true,
      "config": {
        "annotation-flush.backup": "false",
        "annotation-flush.input-key": "annotations.partially-marked",
        "annotation-flush.output-key": "annotations.partially-written"
      }
    },
    {
      "id": "annotation-flush-full",
      "name": "Annotation Flush - Full",
      "entry-point": "IArchitecture.AnnotationFlush.AnnotationFlushProcessor",
      "requires": [ "annotations.fully-marked", "annotations.partially-written" ],
      "provides": [ "annotations.fully-written" ],
      "ide-hidden": true,
      "config": {
        "annotation-flush.backup": "false",
        "annotation-flush.input-key": "annotations.fully-marked",
        "annotation-flush.output-key": "annotations.fully-written"
      }
    }
  ]
}
